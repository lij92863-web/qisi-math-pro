        {"label": "C", "text": "$195\\pi$", "latex": ["195\\pi"]},
        {"label": "D", "text": "$243\\pi$", "latex": ["243\\pi"]}
      ],
      "answer": "C",
      "answerLatex": [],
      "analysisParagraphs": [
        "设圆台的上底面半径为 $r$，下底面半径为 $R$。",
