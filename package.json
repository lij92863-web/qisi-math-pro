{
  "name": "qisi-math-pro-local",
  "version": "1.0.0",
  "private": true,
  "description": "Qisi Math Pro local service",
  "main": "qisi-local-server.js",
  "scripts": {
    "start": "node qisi-local-server.js",
    "check": "node scripts/check-production-syntax.js",
    "test": "node --test",
    "smoke:batch:mock": "node --test tests/batch-smoke-mock.test.js",
    "verify:personal-stable": "npm run verify:docx-stable",
    "verify:docx-stable": "node scripts/verify-docx-stable.js",
    "verify:pdf-known-bad": "node scripts/verify-pdf-known-bad.js",
    "verify:batch-safety": "node scripts/verify-batch-safety.js",
    "verify:no-real-ai": "node scripts/verify-no-real-ai.js",
    "audit:real-materials": "node scripts/audit-real-material-sources.js",
    "verify:diff-scope": "node scripts/verify-diff-scope.js",
    "verify:safe": "npm run check && npm test && npm run smoke:batch:mock && npm run verify:no-real-ai",
    "verify": "npm run check && npm test",
    "test:ai-proxy": "node scripts/smoke-ai-proxy.js",
    "test:ai-vision-proxy": "node scripts/smoke-ai-vision-proxy.js",
    "backup:stage0": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/create-stage0-snapshot.ps1"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^4.18.3",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "playwright": "^1.61.0"
  }
}
